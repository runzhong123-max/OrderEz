page {
  min-height: 100%;
  background: #f7f3ee;
  color: #2f261f;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
image,
scroll-view {
  box-sizing: border-box;
}

.container {
  width: 100%;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
  background: transparent;
  border-radius: 0;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx 24rpx 156rpx;
}

.page-header {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 600;
  color: #2a231d;
  line-height: 1.3;
}

.page-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7b6d61;
}

.card {
  background: #fffdf9;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(80, 58, 34, 0.055);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2f261f;
}

.section-tip {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #8b7d70;
}

.pressable {
  transition: transform 180ms ease, opacity 180ms ease, box-shadow 180ms ease,
    background-color 180ms ease, filter 180ms ease;
  transform: scale(1);
}

.tap-feedback {
  transform: scale(0.982);
  opacity: 0.94;
  filter: brightness(0.985);
}

.tap-feedback-soft {
  transform: scale(0.988);
  opacity: 0.97;
  filter: brightness(0.992);
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: #2f6b4f;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 500;
}

.ghost-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  border: 2rpx solid #d8cec2;
  background: #fffdf9;
  color: #4a4037;
  font-size: 27rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f1ebe3;
  color: #736658;
  font-size: 20rpx;
}

.price-text {
  color: #b85c38;
  font-size: 30rpx;
  font-weight: 600;
}

.empty-state {
  padding: 60rpx 32rpx;
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #342c25;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #86786c;
}

.bottom-panel {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 253, 249, 0.96);
  box-shadow: 0 12rpx 34rpx rgba(76, 56, 36, 0.1);
}
