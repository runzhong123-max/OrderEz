page {
  min-height: 100%;
  background: #f7f3ee;
  color: #2f261f;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
image,
scroll-view {
  box-sizing: border-box;
}

.container {
  width: 100%;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
  background: transparent;
  border-radius: 0;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx 28rpx 180rpx;
}

.page-header {
  margin-bottom: 28rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #2a231d;
  line-height: 1.3;
}

.page-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #7b6d61;
}

.card {
  background: #fffdf9;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 36rpx rgba(80, 58, 34, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2f261f;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  border-radius: 999rpx;
  background: #2f6b4f;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
}

.ghost-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  border-radius: 999rpx;
  border: 2rpx solid #d8cec2;
  background: #fffdf9;
  color: #4a4037;
  font-size: 30rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #f1ebe3;
  color: #736658;
  font-size: 22rpx;
}

.price-text {
  color: #b85c38;
  font-size: 34rpx;
  font-weight: 600;
}

.empty-state {
  padding: 72rpx 40rpx;
  text-align: center;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #342c25;
}

.empty-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #86786c;
}

.bottom-panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 32rpx;
  padding: 20rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 253, 249, 0.96);
  box-shadow: 0 16rpx 48rpx rgba(76, 56, 36, 0.12);
}
