.cart-page {
  background:
    radial-gradient(circle at top right, rgba(205, 228, 204, 0.24), transparent 30%),
    #f7f3ee;
}

.cart-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.cart-card {
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
  align-items: flex-start;
}

.cart-image {
  width: 132rpx;
  height: 132rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
}

.cart-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.cart-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  min-width: 0;
}

.cart-main {
  flex: 1;
  min-width: 0;
}

.cart-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d241d;
  line-height: 1.45;
  word-break: break-all;
}

.cart-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #85786b;
  word-break: break-all;
}

.cart-price {
  flex-shrink: 0;
  padding-top: 2rpx;
}

.cart-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 14rpx;
  min-width: 0;
}

.remove-link {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1.4;
  color: #9a6f56;
  white-space: nowrap;
}

.stepper-shell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 148rpx;
  max-width: 148rpx;
  min-width: 148rpx;
  padding: 4rpx;
  border-radius: 999rpx;
  background: #f4ede5;
  flex-shrink: 0;
}

.stepper-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #54483d;
  font-size: 24rpx;
  line-height: 1;
}

.stepper-value {
  min-width: 28rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 500;
  color: #2f261f;
}

.checkout-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.checkout-total {
  font-size: 31rpx;
  font-weight: 600;
  color: #2f261f;
}

.checkout-tip {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #887b6f;
  line-height: 1.6;
}

.checkout-btn {
  width: 176rpx;
  flex-shrink: 0;
}

.empty-btn {
  margin-top: 36rpx;
}
