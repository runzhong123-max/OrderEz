<view class="page-shell cart-page">
  <view class="page-header">
    <view class="page-title">购物车</view>
    <view class="page-desc">先确认一下已选菜品，数量和金额都可以在这里调整。</view>
  </view>

  <view wx:if="{{!cartState.isEmpty}}">
    <view class="cart-list">
      <view class="cart-card card" wx:for="{{cartState.items}}" wx:key="dishId">
        <image class="cart-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="cart-content">
          <view class="cart-top">
            <view class="cart-main">
              <view class="cart-name">{{item.name}}</view>
              <view class="cart-desc">{{item.description}}</view>
            </view>
            <view class="cart-price price-text">¥{{item.subtotal}}</view>
          </view>
          <view class="cart-actions">
            <view class="remove-link pressable" hover-class="tap-feedback-soft" data-id="{{item.dishId}}" bindtap="removeItem">删除</view>
            <view class="stepper-shell">
              <view class="stepper-btn pressable" hover-class="tap-feedback" data-id="{{item.dishId}}" bindtap="decreaseCount">-</view>
              <view class="stepper-value">{{item.quantity}}</view>
              <view class="stepper-btn pressable" hover-class="tap-feedback" data-id="{{item.dishId}}" bindtap="increaseCount">+</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-panel">
      <view class="checkout-bar">
        <view>
          <view class="checkout-total">合计 ¥{{cartState.totalAmount}}</view>
          <view class="checkout-tip">确认菜品后再下单，支付能力会在后续单独接入。</view>
        </view>
        <button class="primary-btn checkout-btn pressable" hover-class="tap-feedback" bindtap="goCheckout">去结算</button>
      </view>
    </view>
  </view>

  <view wx:else class="card empty-state">
    <view class="empty-title">购物车还是空的</view>
    <view class="empty-desc">先去选几样菜吧，热菜和主食都已经准备好了。</view>
    <button class="primary-btn empty-btn pressable" hover-class="tap-feedback" bindtap="goMenu">再逛逛</button>
  </view>
</view>
