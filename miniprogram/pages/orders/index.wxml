<view class="page-shell orders-page">
  <view class="page-header">
    <view class="page-title">订单</view>
    <view class="page-desc">已提交的订单都会留在这里，方便随时回来看看。</view>
  </view>

  <view wx:if="{{orders.length}}" class="order-list">
    <view class="order-card card pressable" hover-class="tap-feedback-soft" wx:for="{{orders}}" wx:key="id">
      <view class="order-head">
        <view>
          <view class="order-id">订单号 {{item.id}}</view>
          <view class="order-time">{{item.createdAt}}</view>
        </view>
        <view class="order-status">{{item.status}}</view>
      </view>

      <view class="order-summary">{{item.summary}}</view>

      <view class="order-items">
        <view class="order-item" wx:for="{{item.items}}" wx:key="dishId">
          <text>{{item.name}}</text>
          <text>x{{item.quantity}}</text>
        </view>
      </view>

      <view class="order-foot">
        <view class="order-payment">{{item.paymentStatus}}</view>
        <view class="price-text">¥{{item.payableAmount || item.totalAmount}}</view>
      </view>
    </view>
  </view>

  <view wx:else class="card empty-state">
    <view class="empty-title">暂无订单</view>
    <view class="empty-desc">还没有下单记录，先去看看今天的菜单吧。</view>
    <button class="primary-btn empty-btn pressable" hover-class="tap-feedback" bindtap="goMenu">去点餐</button>
  </view>
</view>
