.menu-page {
  background:
    radial-gradient(circle at top left, rgba(241, 214, 173, 0.22), transparent 30%),
    #f7f3ee;
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 18rpx;
  padding: 8rpx 0 20rpx;
}

.category-item {
  padding: 20rpx 30rpx;
  border-radius: 999rpx;
  background: #f1ebe3;
  color: #786b5e;
  font-size: 26rpx;
}

.category-item-active {
  background: #2f6b4f;
  color: #ffffff;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 8rpx;
}

.dish-card {
  display: flex;
  gap: 22rpx;
  padding: 22rpx;
}

.dish-image {
  width: 190rpx;
  height: 190rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
}

.dish-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.dish-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.5;
  color: #2f261f;
}

.dish-desc {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #7e7063;
}

.dish-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 188rpx;
  height: 72rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: #efe5d6;
  color: #6d553f;
  font-size: 26rpx;
}

.cart-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.cart-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2f261f;
}

.cart-tip {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #84776a;
}

.cart-action {
  width: 212rpx;
  flex-shrink: 0;
}
