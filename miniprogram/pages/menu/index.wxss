.menu-page {
  background:
    radial-gradient(circle at top left, rgba(241, 214, 173, 0.22), transparent 30%),
    #f7f3ee;
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 14rpx;
  padding: 6rpx 0 18rpx;
}

.category-item {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: #f1ebe3;
  color: #786b5e;
  font-size: 24rpx;
}

.category-count {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  text-align: center;
  line-height: 32rpx;
  font-size: 20rpx;
}

.category-item-active {
  background: #2f6b4f;
  color: #ffffff;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 6rpx;
}

.dish-card {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
}

.dish-image {
  width: 164rpx;
  height: 164rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
}

.dish-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.dish-name {
  flex: 1;
  font-size: 29rpx;
  font-weight: 600;
  line-height: 1.5;
  color: #2f261f;
}

.dish-desc {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #7e7063;
}

.dish-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  gap: 12rpx;
}

.dish-price {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dish-selected {
  font-size: 20rpx;
  color: #7e7063;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 152rpx;
  height: 62rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #efe5d6;
  color: #6d553f;
  font-size: 24rpx;
}

.cart-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.cart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f261f;
}

.cart-tip {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #84776a;
}

.cart-action {
  width: 178rpx;
  flex-shrink: 0;
}
