<view class="page-shell menu-page">
  <view class="page-header">
    <view class="page-title">今天吃点什么</view>
    <view class="page-desc">{{restaurant.notice}}</view>
  </view>

  <scroll-view class="category-scroll" scroll-x="true" show-scrollbar="false">
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-item pressable {{activeCategoryId === item.id ? 'category-item-active' : ''}}"
        hover-class="tap-feedback-soft"
        data-id="{{item.id}}"
        bindtap="selectCategory"
      >
        <text>{{item.name}}</text>
        <text wx:if="{{item.selectedCount}}" class="category-count">{{item.selectedCount}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="dish-list">
    <view class="dish-card card" wx:for="{{dishList}}" wx:key="id">
      <image class="dish-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="dish-content">
        <view class="dish-top">
          <view class="dish-name">{{item.name}}</view>
          <view class="tag" wx:if="{{item.tag}}">{{item.tag}}</view>
        </view>
        <view class="dish-desc">{{item.description}}</view>
        <view class="dish-bottom">
          <view class="dish-price">
            <view class="price-text">¥{{item.price}}</view>
            <view wx:if="{{item.cartQuantity}}" class="dish-selected">已选 {{item.cartQuantity}}{{item.unit}}</view>
          </view>
          <button class="add-btn pressable" hover-class="tap-feedback" data-id="{{item.id}}" bindtap="addToCart">
            {{item.cartQuantity ? '再来一份' : '加入购物车'}}
          </button>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-panel">
    <view class="cart-bar">
      <view>
        <view class="cart-title">已选 {{cartSummary.totalCount}} 份</view>
        <view class="cart-tip">
          {{cartSummary.isEmpty ? '选好后可以去购物车调整数量。' : '合计 ¥' + cartSummary.totalAmount}}
        </view>
      </view>
      <button class="primary-btn cart-action pressable" hover-class="tap-feedback" bindtap="goCart">去购物车</button>
    </view>
  </view>
</view>
