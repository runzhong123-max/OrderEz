.home-page {
  background:
    radial-gradient(circle at top right, rgba(223, 195, 150, 0.26), transparent 36%),
    #f7f3ee;
}

.hero {
  position: relative;
  overflow: hidden;
  min-height: 360rpx;
}

.hero-image {
  width: 100%;
  height: 360rpx;
}

.hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(53, 41, 28, 0.18), rgba(45, 36, 27, 0.72));
}

.hero-content {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 30rpx;
}

.hero-tag {
  display: inline-flex;
  height: 44rpx;
  padding: 0 18rpx;
  align-items: center;
  border-radius: 999rpx;
  background: rgba(255, 248, 240, 0.2);
  color: #fff8f0;
  font-size: 22rpx;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 56rpx;
  font-weight: 600;
  color: #fffaf4;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 250, 244, 0.9);
}

.intro {
  margin-top: 24rpx;
  padding: 28rpx;
}

.intro-text {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #594c41;
}

.intro-grid {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.intro-item {
  flex: 1;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f6efe6;
}

.intro-label {
  font-size: 22rpx;
  color: #907f70;
}

.intro-value {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #332a22;
}

.notice {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #fbf6f0;
  color: #7d6d5d;
  font-size: 24rpx;
  line-height: 1.7;
}

.entry-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx;
}

.entry-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2e251e;
}

.entry-desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #817365;
}

.entry-btn {
  width: 220rpx;
  flex-shrink: 0;
}

.quick {
  margin-top: 24rpx;
  padding: 28rpx;
}

.quick-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.quick-item {
  flex: 1;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f6efe6;
}

.quick-number {
  font-size: 56rpx;
  font-weight: 600;
  color: #2f6b4f;
}

.quick-label {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7a6d61;
}
